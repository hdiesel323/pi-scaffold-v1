# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Usage: source .env && pi
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# MiniMax (discover models with: pi --list-models minimax)
MINIMAX_API_KEY=

# ZAI (discover models with: pi --list-models zai)
ZAI_API_KEY=

# Groq (discover models with: pi --list-models groq)
GROQ_API_KEY=

# xAI / Grok (discover models with: pi --list-models xai)
XAI_API_KEY=

# Tip: Pi's available model IDs change over time and depend on your authenticated
# providers. After adding keys, run `pi --list-models` and use `/model` or
# `pi --model provider/model-id` with a model from that list.

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# ─────────────────────────────────────────────
#  Sentry (Error Monitoring)
#  Get your DSN from: Sentry.io -> Project -> Settings -> Client Keys
#  Example: https://abc123@o4507818.ingest.us.sentry.io/4507818000000000
# ─────────────────────────────────────────────

SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Environment
NODE_ENV=development
