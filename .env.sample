# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Usage: source .env && pi
# ─────────────────────────────────────────────

# Anthropic (Primary)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# Mistral AI
MISTRAL_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Groq (use: pi --model groq/llama-3.3-70b)
GROQ_API_KEY=

# xAI / Grok (use: pi --model xai/grok-2)
XAI_API_KEY=

# MiniMax (use: pi --model minimax/chatgpt-o3-mini)
MINIMAX_API_KEY=

# ZAI (use: pi --model zai/Bests)
ZAI_API_KEY=

# Azure OpenAI (Requires endpoint in .taskmaster/config.json)
AZURE_OPENAI_API_KEY=

# Ollama (For remote servers requiring auth)
OLLAMA_API_KEY=

# GitHub (For import/export features)
GITHUB_API_KEY=ghp_...
GITHUB_TOKEN=ghp_...

# Search & Research
TAVILY_API_KEY=tvly-...

# Integration
NOTION_TOKEN=secret_...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# ─────────────────────────────────────────────
#  Sentry (Error Monitoring)
#  Get your DSN from: Sentry.io -> Project -> Settings -> Client Keys
# ─────────────────────────────────────────────

SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Environment
NODE_ENV=development
