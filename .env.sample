# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Usage: source .env && pi
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# MiniMax (use: pi --model minimax/chatgpt-o3-mini)
MINIMAX_API_KEY=

# ZAI (use: pi --model zai/Bests)
ZAI_API_KEY=

# Groq (use: pi --model groq/llama-3.3-70b)
GROQ_API_KEY=

# xAI / Grok (use: pi --model xai/grok-2)
XAI_API_KEY=

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# ─────────────────────────────────────────────
#  Sentry (Error Monitoring)
#  Get your DSN from: Sentry.io -> Project -> Settings -> Client Keys
#  Example: https://abc123@o4507818.ingest.us.sentry.io/4507818000000000
# ─────────────────────────────────────────────

SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Environment
NODE_ENV=development
